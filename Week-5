1. Question: Write a C++ program to perform addition of n elements using dynamic memory allocation.
Program:
#include <iostream>
using namespace std;

int main()
{
    int *a, n, i, sum = 0;
cout << "Enter number of elements: ";
    cin >> n;
 a = new int[n];
 cout << "Enter elements:\n";
    for(i = 0; i < n; i++)
    {
        cin >> a[i];
        sum += a[i];
    }
 cout << "Sum of elements = " << sum;
 delete[] a;
    return 0;
}
Output:
Enter number of elements: 5
Enter elements:
10 20 30 40 50
Sum of elements = 150


2. Question: Write a C++ program to create four nodes in a single linked list using dynamic memory allocation.
Program:
#include <iostream>
using namespace std;

struct Node
{
    int data;
    Node* next;
};

int main()
{
    Node *head, *second, *third, *fourth;
  head = new Node();
    second = new Node();
    third = new Node();
